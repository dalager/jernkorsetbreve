  "notable": {
    "most_negative": [
      {
        "id": 88,
        "date": "1914-08-25",
        "sender": "Peter Mærsk",
        "recipient": "Mor og far",
        "score": -0.2712,
        "excerpt": "Da jeg kom tilbage, var det et skrækkelig syn, vor komp. havde stormet og var blevet slået tilbage."
      },
      {
        "id": 154,
        "date": "1915-04-21",
        "sender": "Peter Mærsk",
        "recipient": "Mor og far",
        "score": -0.1643,
        "excerpt": "Hvis Truls blot vidste hvad det kan koste ham, hvis det kommer ud."
      },
      {
        "id": 133,
        "date": "1915-02-02",
        "sender": "Peter Mærsk",
        "recipient": "Hejmdal (Sønderjysk avis)",
        "score": -0.1488,
        "excerpt": "Vi har som Følge deraf en meget farlig Stilling."
      },
      {
        "id": 329,
        "date": "1916-07-01",
        "sender": "Peter Mærsk",
        "recipient": "Mor og far",
        "score": -0.1306,
        "excerpt": "Har de mod til at se deres egne Folk lide."
      },
      {
        "id": 56,
        "date": "1914-04-18",
        "sender": "Peter Mærsk",
        "recipient": "Mor og far",
        "score": -0.106,
        "excerpt": "Jeg havde nu en lille tryk med det samme, jeg var med til tjeneste en time, og svedte helt tosset."
      },
      {
        "id": 149,
        "date": "1915-04-13",
        "sender": "Peter Mærsk",
        "recipient": "Mor og far",
        "score": -0.1049,
        "excerpt": "Og der skulle 40 mand fra vor Komp."
      },
      {
        "id": 30,
        "date": "1913-09-01",
        "sender": "Peter Mærsk",
        "recipient": "Trine Mærsk",
        "score": -0.0949,
        "excerpt": "Ja dårlig er det skrevet"
      },
      {
        "id": 1,
        "date": "1911-03-06",
        "sender": "Peter Mærsk",
        "recipient": "Trine Mærsk",
        "score": -0.0943,
        "excerpt": "Men så syntes vi at det var en Skam sådan at sætte dem på Døren."
      },
      {
        "id": 464,
        "date": "1917-07-15",
        "sender": "Peter Mærsk",
        "recipient": "Mor og far",
        "score": -0.0924,
        "excerpt": "Så kom den første Melding som lød: Vi - højre fløj - er inde i Graven - mangler forstærkning - har store tab."
      },
      {
        "id": 181,
        "date": "1915-08-01",
        "sender": "Peter Mærsk",
        "recipient": "Trine Mærsk",
        "score": -0.0881,
        "excerpt": "Ja havde de sagt mig at jeg skulle gå det igennem som jeg har gået igennem, så havde jeg sagt, så vil jeg hellere dø på stedet."
      }
    ],
    "most_positive": [
      {
        "id": 665,
        "date": "1918-08-30",
        "sender": "Peter Mærsk",
        "recipient": "Maren Mærsk",
        "score": 0.7695,
        "excerpt": "Hjertelig tillykke på din Fødselsdag."
      },
      {
        "id": 23,
        "date": "1912-12-26",
        "sender": "Niels og Maren Hansen",
        "recipient": "Peter Mærsk",
        "score": 0.6796,
        "excerpt": "Det fryder mig hvert år at se den glæde eleverne rejser til deres hjem med."
      },
      {
        "id": 606,
        "date": "1918-04-19",
        "sender": "Uffe",
        "recipient": "Maren Mærsk",
        "score": 0.6591,
        "excerpt": "Mange Hilsner jeres"
      },
      {
        "id": 545,
        "date": "1917-12-17",
        "sender": "Peter Mærsk",
        "recipient": "Trine Mærsk",
        "score": 0.6468,
        "excerpt": "For så vidt må vi takke Gud, og jeg siger altid at indtil nu har Gud sat os mellem de lykkeligste."
      },
      {
        "id": 617,
        "date": "1918-05-23",
        "sender": "Peter Mærsk",
        "recipient": "Mor og far",
        "score": 0.636,
        "excerpt": "Nu mange kærlige Hilsener sender jeres taknemmelige Peer."
      },
      {
        "id": 380,
        "date": "1917-01-12",
        "sender": "Peter Mærsk",
        "recipient": "Trine Mærsk",
        "score": 0.6189,
        "excerpt": ".Kærlige Hilsner sender dig to gode Venner"
      },
      {
        "id": 356,
        "date": "1916-11-19",
        "sender": "Peter Mærsk",
        "recipient": "Trine Mærsk",
        "score": 0.5861,
        "excerpt": "Mange kærlige Hilsner fra det fjærne Osten sender dig"
      },
      {
        "id": 544,
        "date": "1917-12-16",
        "sender": "Peter Mærsk",
        "recipient": "Mor og far",
        "score": 0.5736,
        "excerpt": "Til slut mange kærlige Hilsener"
      },
      {
        "id": 650,
        "date": "1918-07-25",
        "sender": "Uffe",
        "recipient": "Trine Mærsk",
        "score": 0.5697,
        "excerpt": "Det glæder mig også meget, at Signe nu er kommet til at se Dig som sin ældre søster og bedste veninde i al ting."
      },
      {
        "id": 608,
        "date": "1918-04-24",
        "sender": "Peter Mærsk",
        "recipient": "Mor og far",
        "score": 0.5694,
        "excerpt": "Herlig er det ude."
      }
    ],
    "widest_range": [
      {
        "id": 284,
        "date": "1916-04-09",
        "sender": "Peter Mærsk",
        "recipient": "Mor og far",
        "score": 0.1024,
        "excerpt": "Og hans mor tog det så nær, at hun blev så syg og svagelig."
      },
      {
        "id": 150,
        "date": "1915-04-15",
        "sender": "Peter Mærsk",
        "recipient": "Mor og far",
        "score": 0.1993,
        "excerpt": "Selve pakken måtte jeg smide bort, alt hvad der var i den var ødelagt."
      },
      {
        "id": 426,
        "date": "1917-04-08",
        "sender": "Peter Mærsk",
        "recipient": "Mor og far",
        "score": 0.1385,
        "excerpt": "Det skal have set skrækkelig ud der ovre."
      },
      {
        "id": 376,
        "date": "1917-01-04",
