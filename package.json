{
  "name": "jernkorsetbreve",
  "private": true,
  "scripts": {
    "data:build": "node scripts/build-data.mjs",
    "data:embed": "node scripts/generate-embeddings.mjs",
    "data:reindex": "node scripts/generate-embeddings.mjs --force",
    "data:battles": "node scripts/generate-battle-data.mjs",
    "data:clusters": "node scripts/generate-clusters.mjs",
    "data:audit": "python scripts/audit-text-quality.py",
    "data:correct": "python scripts/apply-corrections.py",
    "data:validate": "python scripts/validate-text-quality.py",
    "data:normalize": "node scripts/normalize-danish.mjs",
    "data:sentences": "python scripts/extract-sentences-normalized.py",
    "data:sentiment": "python scripts/generate-sentiments-cvp.py",
    "data:enrich-places": "python scripts/enrich-places-wikidata.py",
    "data:borders": "node scripts/build-historical-borders.mjs",
    "data:emotion-vectors": "python scripts/generate-emotion-vectors.py",
    "data:emotions": "python scripts/generate-emotions-cvp.py",
    "data:psycholinguistics": "python scripts/analyze-psycholinguistics.py",
    "data:audience": "python scripts/analyze-audience-divergence.py",
    "data:arcs": "python scripts/analyze-narrative-arcs.py",
    "data:identity": "python scripts/generate-identity-vector.py",
    "data:semantic-shifts": "python scripts/detect-semantic-shifts.py",
    "data:pca": "python scripts/discover-embedding-dimensions.py",
    "data:ner": ".venv/Scripts/python.exe scripts/adr016_b1_dacy_ner.py",
    "data:entity-audit": ".venv/Scripts/python.exe scripts/adr016_a2_entity_audit.py",
    "data:person-registry": ".venv/Scripts/python.exe scripts/adr016_b2_person_registry.py",
    "data:social-network": ".venv/Scripts/python.exe scripts/adr016_c1_social_network.py",
    "data:disappearance": ".venv/Scripts/python.exe scripts/adr016_e1_disappearance.py",
    "data:network-all": "npm run data:ner && npm run data:entity-audit && npm run data:person-registry && npm run data:social-network && npm run data:disappearance",
    "data:all": "npm run data:audit && npm run data:correct && npm run data:validate && npm run data:normalize && npm run data:sentences && npm run data:sentiment && npm run data:emotion-vectors && npm run data:emotions && npm run data:psycholinguistics && npm run data:audience && npm run data:arcs && npm run data:semantic-shifts && npm run data:enrich-places && npm run data:network-all && npm run data:build && npm run data:battles && npm run data:reindex && npm run data:clusters && npm run data:borders",
    "dev": "cd apps/website && npm run dev",
    "build": "npm run data:all && cd apps/website && npm run build",
    "build:site": "cd apps/website && npm install && npm run build",
    "preview": "npx serve apps/website/out",
    "lint": "npm run lint:eslint && npm run lint:types && npm run lint:danish",
    "lint:eslint": "cd apps/website && npx eslint src/",
    "lint:types": "cd apps/website && npx tsc --noEmit",
    "lint:danish": "bash scripts/lint-danish-chars.sh",
    "eval:search": "node scripts/evaluate-search.mjs",
    "eval:search:save": "node scripts/evaluate-search.mjs --save",
    "eval:search:verbose": "node scripts/evaluate-search.mjs --verbose"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "onnxruntime-node": "^1.24.3",
    "ruflo": "^3.5.48",
    "umap-js": "^1.4.0"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
